#!groovy

@Library("Infrastructure@dev/DTSPO-28281") _

def type = "java"
def product = "toffee"
def component = "recipe-backend"

// Stops sbox DBs being removed and blocking our builds
def expiresAfter = "3000-01-01"

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

def envName = new uk.gov.hmcts.contino.Environment(env).nonProdName

withPipeline(type, product, component) {
  enableFortifyScan("${product}si-${envName}")
  expires(expiresAfter)
}
